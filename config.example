# Driver names as reported by /sys/class/net/wlanX/device/driver
# Run: basename "$(readlink /sys/class/net/wlan0/device/driver)"
DRIVER_5G="your_5g_driver"
DRIVER_24G="your_24g_driver"

# Fixed channels for each band
CHANNEL_5G=0
CHANNEL_24G=0

# Access point BSSIDs (one per band)
AP_BSSID_5G="AA:BB:CC:DD:EE:01"
AP_BSSID_24G="AA:BB:CC:DD:EE:02"

# Spoofed MAC address applied before enabling monitor mode
MAC_SPOOF="AA:BB:CC:DD:EE:FF"

# Path to the file containing one target MAC per line
BLACKLIST="$HOME/your_blacklist_file"

# How often (in seconds) the watchdog checks for channel drift
WATCHDOG_INTERVAL=30

# Deauth bursts per cycle per worker (lower = faster rotation)
DEAUTH_COUNT=1

# Seconds between bursts within each worker
DEAUTH_SLEEP=0.5

# Max workers launched per batch before staggering
MAX_PARALLEL=4

# Seconds between batches at startup to avoid saturating the adapter
STAGGER_DELAY=0.3
